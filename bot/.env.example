# Telegram bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Your deployed API base URL (no trailing slash)
# On Render: https://your-app.onrender.com/api
API_BASE_URL=https://your-app.onrender.com/api

# Full URL to ping for keep-alive (optional, defaults to API_BASE_URL/healthz)
SELF_URL=https://your-app.onrender.com/api/healthz
